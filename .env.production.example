# E-Malla Rwanda production environment template
# Keep real secrets only in your hosting providers. Do not commit them.

# Frontend (Vercel)
VITE_API_URL=https://api.yourdomain.com/api
VITE_PUBLIC_APP_URL=https://www.emallarwanda.com

# Backend runtime
NODE_ENV=production
PORT=4000
DB_PROVIDER=postgres
DATABASE_URL=postgresql://user:password@host:5432/emalla
PUBLIC_APP_URL=https://www.emallarwanda.com
CORS_ALLOWED_ORIGINS=https://emallarwanda.com,https://www.emallarwanda.com
JWT_SECRET=replace_with_long_random_jwt_secret
SESSION_SECRET=replace_with_long_random_session_secret
AUTH_SESSION_MAX_AGE_DAYS=30
TRUST_PROXY=true
LOG_LEVEL=info

# Email (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM_EMAIL=no-reply@yourdomain.com
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=E-Malla Rwanda
ADMIN_ALERT_EMAIL=admin@yourdomain.com

# Storage (Cloudinary)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=replace_with_cloudinary_cloud_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=e-malla
MAX_IMAGE_UPLOAD_MB=8
MAX_DOCUMENT_UPLOAD_MB=12

# Backend-only integrations
GEMINI_API_KEY=replace_with_backend_only_gemini_key

# Bootstrap / maintenance
ADMIN_BOOTSTRAP_PASSWORD=replace_with_strong_admin_bootstrap_password
BUYER_BOOTSTRAP_PASSWORD=replace_with_strong_buyer_bootstrap_password
MERCHANT_BOOTSTRAP_PASSWORD=replace_with_strong_seller_bootstrap_password
RIDER_BOOTSTRAP_PASSWORD=replace_with_strong_rider_bootstrap_password
DB_BACKUP_RETENTION=10

# Validation helpers
# npm run env:check
# npm run email:check
# npm run storage:check
# npm run db:postgres:check
# Temporary GTBank payment collection partner. Update these when the account moves to E-Malla.
GTBANK_MERCHANT_CODE=551000093
GTBANK_RECIPIENT_NAME=Perfect Technologies Ltd
VITE_GTBANK_MERCHANT_CODE=551000093
VITE_GTBANK_RECIPIENT_NAME=Perfect Technologies Ltd
